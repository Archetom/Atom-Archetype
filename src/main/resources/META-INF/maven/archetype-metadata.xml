<?xml version="1.0" encoding="UTF-8"?>
<archetype-descriptor
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://maven.apache.org/plugins/maven-archetype-plugin/archetype-descriptor/1.1.0 https://maven.apache.org/xsd/archetype-descriptor-1.1.0.xsd"
        xmlns="https://maven.apache.org/plugins/maven-archetype-plugin/archetype-descriptor/1.1.0"
        name="atom">
    <requiredProperties>
        <requiredProperty key="gitignore">
            <defaultValue>.gitignore</defaultValue>
        </requiredProperty>
    </requiredProperties>
    <fileSets>
        <fileSet filtered="true" encoding="UTF-8">
            <directory/>
            <includes>
                <include>__gitignore__</include>
                <include>lombok.config</include>
                <include>Makefile</include>
                <include>*.yml</include>
                <include>conf/*</include>
            </includes>
        </fileSet>
        <fileSet filtered="true" encoding="UTF-8">
            <directory/>
            <includes>
                <include>README.md</include>
                <include>README.en.md</include>
                <include>llms.txt</include>
                <include>LICENSE</include>
            </includes>
        </fileSet>
        <!-- Keep scripts and wrapper configuration unfiltered: ${...} expressions are not Velocity here. -->
        <fileSet filtered="false" encoding="UTF-8">
            <directory/>
            <includes>
                <include>clean.sh</include>
                <include>AGENTS.md</include>
                <include>mvnw</include>
                <include>mvnw.cmd</include>
                <include>.mvn/wrapper/maven-wrapper.properties</include>
            </includes>
        </fileSet>
        <!-- add docs directory -->
        <fileSet filtered="false" encoding="UTF-8">
            <directory>docs</directory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>
    </fileSets>
    <modules>
        <!-- api -->
        <module id="${rootArtifactId}-api" dir="api" name="${rootArtifactId}-api">
            <fileSets>
                <fileSet filtered="true" packaged="true" encoding="UTF-8">
                    <directory>src/main/java</directory>
                    <includes>
                        <include>**/*.java</include>
                    </includes>
                </fileSet>
            </fileSets>
        </module>
        <!-- common -->
        <module id="${rootArtifactId}-shared" dir="shared" name="${rootArtifactId}-shared">
            <fileSets>
                <fileSet filtered="true" packaged="true" encoding="UTF-8">
                    <directory>src/main/java</directory>
                    <includes>
                        <include>**/*.java</include>
                    </includes>
                </fileSet>
                <fileSet filtered="true" packaged="true" encoding="UTF-8">
                    <directory>src/test/java</directory>
                    <includes>
                        <include>**/*.java</include>
                    </includes>
                </fileSet>
            </fileSets>
        </module>
        <!-- application -->
        <module id="${rootArtifactId}-application" dir="application" name="${rootArtifactId}-application">
            <fileSets>
                <fileSet filtered="true" packaged="true" encoding="UTF-8">
                    <directory>src/main/java</directory>
                    <includes>
                        <include>**/*.java</include>
                    </includes>
                </fileSet>
                <fileSet filtered="true" packaged="true" encoding="UTF-8">
                    <directory>src/test/java</directory>
                    <includes>
                        <include>**/*.java</include>
                    </includes>
                </fileSet>
            </fileSets>
        </module>
        <!-- domain -->
        <module id="${rootArtifactId}-domain" dir="domain" name="${rootArtifactId}-domain">
            <fileSets>
                <fileSet filtered="true" packaged="true" encoding="UTF-8">
                    <directory>src/main/java</directory>
                    <includes>
                        <include>**/*.java</include>
                    </includes>
                </fileSet>
                <fileSet filtered="true" packaged="true" encoding="UTF-8">
                    <directory>src/test/java</directory>
                    <includes>
                        <include>**/*.java</include>
                    </includes>
                </fileSet>
            </fileSets>
        </module>
        <!-- infra-external -->
        <module id="${rootArtifactId}-infra-external" dir="infra/external" name="${rootArtifactId}-infra-external">
            <fileSets>
                <fileSet filtered="true" packaged="true" encoding="UTF-8">
                    <directory>src/main/java</directory>
                    <includes>
                        <include>**/*.java</include>
                    </includes>
                </fileSet>
                <fileSet filtered="true" encoding="UTF-8">
                    <directory>src/main/resources</directory>
                </fileSet>
            </fileSets>
        </module>
        <!-- infra-security -->
        <module id="${rootArtifactId}-infra-security" dir="infra/security" name="${rootArtifactId}-infra-security">
            <fileSets>
                <fileSet filtered="true" packaged="true" encoding="UTF-8">
                    <directory>src/main/java</directory>
                    <includes>
                        <include>**/*.java</include>
                    </includes>
                </fileSet>
            </fileSets>
        </module>
        <!-- infra-persistence -->
        <module id="${rootArtifactId}-infra-persistence" dir="infra/persistence" name="${rootArtifactId}-infra-persistence">
            <fileSets>
                <fileSet filtered="true" packaged="true" encoding="UTF-8">
                    <directory>src/main/java</directory>
                    <includes>
                        <include>**/*.java</include>
                    </includes>
                </fileSet>
                <fileSet filtered="true" packaged="true" encoding="UTF-8">
                    <directory>src/test/java</directory>
                    <includes>
                        <include>**/*.java</include>
                    </includes>
                </fileSet>
                <fileSet filtered="true" encoding="UTF-8">
                    <directory>src/main/resources</directory>
                </fileSet>
            </fileSets>
        </module>
        <!-- infra-rest -->
        <module id="${rootArtifactId}-infra-rest" dir="infra/rest" name="${rootArtifactId}-infra-rest">
            <fileSets>
                <fileSet filtered="true" packaged="true" encoding="UTF-8">
                    <directory>src/main/java</directory>
                    <includes>
                        <include>**/*.java</include>
                    </includes>
                </fileSet>
                <fileSet filtered="true" packaged="true" encoding="UTF-8">
                    <directory>src/test/java</directory>
                    <includes>
                        <include>**/*.java</include>
                    </includes>
                </fileSet>
                <fileSet filtered="true" encoding="UTF-8">
                    <directory>src/main/resources</directory>
                </fileSet>
            </fileSets>
        </module>
        <!-- infra-facade -->
        <module id="${rootArtifactId}-infra-facade" dir="infra/facade" name="${rootArtifactId}-infra-facade">
            <fileSets>
                <fileSet filtered="true" packaged="true" encoding="UTF-8">
                    <directory>src/main/java</directory>
                    <includes>
                        <include>**/*.java</include>
                    </includes>
                </fileSet>
                <fileSet filtered="true" encoding="UTF-8">
                    <directory>src/main/resources</directory>
                </fileSet>
            </fileSets>
        </module>
        <!-- start -->
        <module id="${rootArtifactId}-start" dir="start" name="${rootArtifactId}-start">
            <fileSets>
                <fileSet filtered="true" packaged="true" encoding="UTF-8">
                    <directory>src/main/java</directory>
                    <includes>
                        <include>**/*.java</include>
                    </includes>
                </fileSet>
                <fileSet filtered="true" packaged="true" encoding="UTF-8">
                    <directory>src/test/java</directory>
                    <includes>
                        <include>**/*.java</include>
                    </includes>
                </fileSet>
                <fileSet filtered="true" encoding="UTF-8">
                    <directory>../conf</directory>
                </fileSet>
            </fileSets>
        </module>
    </modules>
</archetype-descriptor>
